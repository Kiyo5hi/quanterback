最近 10 次 scan_runs
================================================================================
{% for s in scan_runs[:10] %}
  [#{{ s.id }}] {{ s.started }} — {{ s.ended }} ({{ s.duration }}s)
    来源:       {{ s.source }}
    代码数:     {{ s.tickers_processed }}
    错误:       {{ s.errors_count }}
{% endfor %}

================================================================================
最近 20 次决策
================================================================================
{% for d in decisions[:20] %}
  {{ d.ts }}: {{ d.ticker }} — {{ d.action }} ({{ d.conf }})
    {{ d.rationale_short[:70] }}
{% endfor %}

================================================================================
决策行动分布
================================================================================
{% for action, count, pct in action_dist %}
  {{ action }}: {{ count }} ({{ pct }}%)
{% endfor %}

================================================================================
跳过/拒绝原因 (最近 100, top 5)
================================================================================
{% for r in rejection_reasons %}
  {{ r.reason }}: {{ r.count }}
{% endfor %}

================================================================================
持仓
================================================================================
{% if open_positions %}
{% for p in open_positions %}
  {{ p.ticker }}: {{ p.shares }} @ {{ p.entry_price }} ({{ p.current_price }})
    SL: {{ p.stop_loss }}  TP: {{ p.take_profit }}
{% endfor %}
{% else %}
  (无)
{% endif %}

================================================================================
